import subprocess
import re
import json
import argparse
from tabulate import tabulate

RED = "\033[91m"
YELLOW = "\033[93m"
RESET = "\033[0m"

def get_ssh_logs(since_filter, until_filter=None):
    try:
        command = [
            "journalctl",
            "-u",
            "ssh",
            "--since",
            since_filter,
            "--no-pager"
        ]
            
        if until_filter:
            command.extend(["--until", until_filter])
        result = subprocess.run(
            command,
            capture_output=True,
            text=True,
            check=True
        )

        return result.stdout
    except Exception as e:
        print(e)
        return ""
    

def positive_int(value):
    try:
        ivalue = int(value)
    except ValueError:
        raise argparse.ArgumentTypeError("value must be an integer")

    if ivalue <= 0:
        raise argparse.ArgumentTypeError("value must be a positive integer (> 0)")

    return ivalue


def parse_args():
    parser = argparse.ArgumentParser(description="SSH Log Analyzer")
    parser.add_argument("--last", help="Analyze last period (e.g. 30h, 2d, 15m)")
    parser.add_argument("--since", help="Start time (e.g. '2026-04-24 10:00:00')")
    parser.add_argument("--until", help="End time (e.g. '2026-04-24 12:00:00')")
    parser.add_argument("--report", help="Save report to JSON file")
    parser.add_argument("--top", type=positive_int, help="Set the amount of IPs with the most amount of login attempts")
    return parser.parse_args()


def analyze_logs(log_text):
    stats = {
        "failed_password": 0,
        "accepted_password": 0,
        "invalid_user": 0,
        "error": 0,
        "warning": 0
    }
    failed_by_ip = {}
    lines = log_text.splitlines()

    for line in lines:
        lower_line = line.lower()

        if "failed password" in lower_line:
            stats["failed_password"] += 1
            match = re.search(r"\b(?:\d{1,3}\.){3}\d{1,3}\b", line)
            if match:
                ip = match.group()
                failed_by_ip[ip] = failed_by_ip.get(ip, 0) + 1

        if "accepted password" in lower_line:
            stats["accepted_password"] += 1

        if "invalid user" in lower_line:
            stats["invalid_user"] += 1

        if "error" in lower_line:
            stats["error"] += 1

        if "warning" in lower_line:
            stats["warning"] += 1

    return stats, failed_by_ip


def sort_ips(failed_by_ip, top_n):
    sorted_ips = sorted(failed_by_ip.items(), key=lambda x: x[1], reverse=True)
    if top_n:
        return sorted_ips[:top_n]
    return sorted_ips


def print_stats(stats):
    print("\nLog analysis result:")
    for key, value in stats.items():
        print(f"{key}: {value}")


def get_label(count):
    if count >= 50:
        return "Brute force attack"
    elif count >= 20:
        return "Suspicious"
    return ""


def print_failed_by_ip(sorted_ips):
    print("\nFailed password attempts from IP:\n")

    table = []

    for ip, count in sorted_ips:
        label = get_label(count)

        if count >= 50:
            count_display = f"{RED}{count}{RESET}"
            label_display = f"{RED}{label}{RESET}"
        elif count >= 20:
            count_display = f"{YELLOW}{count}{RESET}"
            label_display = f"{YELLOW}{label}{RESET}"
        else:
            count_display = str(count)
            label_display = label

        table.append([
            ip,
            count_display,
            label_display
        ])

    print(tabulate(table, headers=["IP Address", "Attempts", "Status"], tablefmt="grid"))


def build_report(stats, sorted_ips, since_filter, until_filter, top_n, filename):
    ip_analysis = []

    for ip, count in sorted_ips:
        ip_analysis.append({
            "ip": ip,
            "attempts": count,
            "label": get_label(count)
        })

    report_data = {
        "stats": stats,
        "ip_analysis": ip_analysis,
        "since": since_filter,
        "until": until_filter,
        "top": top_n
    }

    with open(filename, "w") as file:
        json.dump(report_data, file, indent=4)


def main():
    args = parse_args()
    if args.last:
        since_filter = f"{args.last} ago"
    elif args.since:
        since_filter = args.since
    else:
        since_filter = "1 hour ago"

    until_filter = args.until
    top_n = args.top

    logs = get_ssh_logs(since_filter, until_filter)
    stats, failed_by_ip = analyze_logs(logs)
    sorted_ips = sort_ips(failed_by_ip, top_n)

    print(f"\nAnalyzing logs since: {since_filter}")
    if until_filter:
        print(f"Analyzing logs until: {until_filter}")

    if top_n:
        print(f"\nThe top: {top_n} IPs:")

    print_stats(stats)
    print_failed_by_ip(sorted_ips)
    
    if args.report:
        build_report(stats, sorted_ips, since_filter, until_filter, top_n, args.report)
        print(f"\nReport saved to {args.report}")


if __name__ == "__main__":
    main()
if __name__ == "__main__":
    main()
